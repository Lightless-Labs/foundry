      "surface_id",
      "surface_class",
      "hidden case name",
      "scene definition",
      "reference image",
      "rendered image",
      "pixel diff",
      "failure reason",
      "comparator rationale"
    ]
  },
  "comparison_contract": {
    "image_size_px": {"width": 64, "height": 48},
    "coordinate_space": "screenshot_px",
    "channels": "RGBA",
    "reruns_per_case": 2,
    "thresholds": {
      "max_changed_pixels_for_pass": 0
    }
  },
