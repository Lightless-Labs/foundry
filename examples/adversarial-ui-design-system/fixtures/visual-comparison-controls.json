{
  "schema_version": "foundry.adversarial-ui.visual-comparison-controls.v1",
  "purpose": "Executable visual comparison controls for adversarial UI: in-memory synthetic scenes plus tiny file-backed raster artifacts, without browser, emulator, device-farm, Pillow, or live vision-model dependencies.",
  "visibility": "red_orchestrator_comparator_only",
  "green_visible_results_contract": {
    "format": "opaque_label_plus_PASS_or_FAIL_only",
    "allowed_examples": ["T-301: PASS", "T-302: FAIL"],
    "forbidden": [
      "surface_id",
      "surface_class",
      "hidden case name",
      "scene definition",
      "reference image",
      "rendered image",
      "pixel diff",
      "failure reason",
      "comparator rationale",
      "screenshot artifact path",
      "screenshot hash",
      "vision prompt",
      "vision model rationale"
    ]
  },
  "comparison_contract": {
    "image_size_px": {"width": 64, "height": 48},
    "coordinate_space": "screenshot_px",
    "channels": "RGBA",
    "reruns_per_case": 2,
    "thresholds": {
      "max_changed_pixels_for_pass": 0
    }
  },
  "cases": [
