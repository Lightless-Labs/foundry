  "file_backed_controls": {
    "purpose": "Tiny checked-in raster fixtures that exercise artifact loading, SHA-256 verification, pixel comparison, negative controls, and rerun agreement. These are screenshot-like surrogate files, not live app/browser/device captures.",
    "source_format": "portable_pixmap_p3",
    "format_note": "ASCII PPM P3 is intentionally used so validation remains Python-stdlib-only; it is a raster artifact surrogate rather than a PNG/browser screenshot claim.",
    "artifact_visibility": "red_orchestrator_comparator_only",
