      "capture_kind": "rendered_capture",
      "expected_outcome": "PASS",
      "reference_scene": {
        "background": "#ffffff",
        "rectangles": [
          {"xy": [4, 4, 60, 44], "fill": "#ffffff", "outline": "#d0d7de"},
          {"xy": [12, 28, 36, 38], "fill": "#2563eb", "outline": "#2563eb"}
        ]
      },
