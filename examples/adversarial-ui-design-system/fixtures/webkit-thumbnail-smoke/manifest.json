{
  "schema_version": "foundry.adversarial-ui.webkit-thumbnail-smoke.v1",
  "purpose": "Rerunnable WebKit/QuickLook thumbnail smoke for one web-browser adversarial UI modality. This is a real renderer thumbnail check, not a viewport-accurate browser screenshot gate.",
  "visibility": "red_orchestrator_comparator_only",
  "surface_id": "surface-web-001",
  "surface_class": "web_browser",
  "capture_kind": "rendered_capture",
  "renderer": {
    "tool": "qlmanage",
    "command_template": "qlmanage -t -s 800 -o <output_dir> <html_file>",
    "dimension_probe": "PNG IHDR via validator; sips -g pixelWidth -g pixelHeight was used during initial capture",
    "thumbnail_size_px": {
      "width": 800,
      "height": 800
    },
    "framing_note": "QuickLook emits a square thumbnail with WebKit-rendered content; scaling/framing/padding are thumbnail semantics, not DOM viewport pixels.",
    "platform_note": "macOS QuickLook/WebKit smoke; keep out of fast aggregate validation and do not generalize to Chrome/Firefox/device reliability."
  },
  "green_visible_results_contract": {
    "format": "opaque_label_plus_PASS_or_FAIL_only",
    "allowed_examples": [
      "T-501: PASS",
      "T-502: FAIL"
    ],
    "forbidden": [
      "HTML hidden-case content",
      "thumbnail path",
      "thumbnail hash",
      "renderer metadata",
      "pixel diff",
      "failure reason",
      "comparator rationale"
    ]
  },
  "thresholds": {
    "rerun_hash_agreement_required": true,
    "pass_reference_rendered_hash_equal": true,
    "fail_reference_rendered_hash_different": true,
    "pixel_delta_threshold": "not_calibrated_for_quicklook_thumbnail_framing"
  },
  "source_html": [
